# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Cloudinary / storage base URL for media assets
NEXT_PUBLIC_STORAGE_URL=http://localhost:8000/storage/

# Internal API URL used by Next.js Server Components
# (same as public URL in most cases, unless behind a proxy)
API_URL=http://localhost:8000/api

# Laravel session cookie name (default: laravel_session)
SESSION_COOKIE_NAME=laravel_session
